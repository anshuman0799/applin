# SMTP email delivery for verification links
MAIL_FROM="Applin <no-reply@example.com>"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-username"
SMTP_PASS="smtp-password"
