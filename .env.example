# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Auth.js
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
