{
  "info": {
    "name": "Applin Local API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Local Postman collection for the Applin API. Import this collection, keep cookies enabled, and run requests in order."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "email",
      "value": "postman-tester@example.com"
    },
    {
      "key": "password",
      "value": "testpass123"
    },
    {
      "key": "csrfToken",
      "value": ""
    },
    {
      "key": "applicationId",
      "value": ""
    },
    {
      "key": "noteId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Tester\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('csrfToken', response.csrfToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/csrf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "csrf"]
            }
          }
        },
        {
          "name": "Sign In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "email",
                  "value": "{{email}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                },
                {
                  "key": "csrfToken",
                  "value": "{{csrfToken}}",
                  "type": "text"
                },
                {
                  "key": "callbackUrl",
                  "value": "{{baseUrl}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/callback/credentials",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "callback", "credentials"]
            }
          }
        },
        {
          "name": "Current Session",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/session",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "session"]
            }
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications"]
            }
          }
        },
        {
          "name": "Create Application",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('applicationId', response.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company\": \"OpenAI\",\n  \"role\": \"Software Engineer\",\n  \"jobLink\": \"https://example.com/jobs/123\",\n  \"location\": \"Remote\",\n  \"status\": \"Screening\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications"]
            }
          }
        },
        {
          "name": "Get Application",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "{{applicationId}}"]
            }
          }
        },
        {
          "name": "Update Application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Interview Round 2\",\n  \"location\": \"San Francisco, CA\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "{{applicationId}}"]
            }
          }
        },
        {
          "name": "Delete Application",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "{{applicationId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "List Notes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "{{applicationId}}", "notes"]
            }
          }
        },
        {
          "name": "Create Note",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set('noteId', response.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Recruiter reached out and scheduled intro call.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "applications", "{{applicationId}}", "notes"]
            }
          }
        },
        {
          "name": "Update Note",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Recruiter reached out, intro call completed, waiting on next round.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "applications",
                "{{applicationId}}",
                "notes",
                "{{noteId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "applications",
                "{{applicationId}}",
                "notes",
                "{{noteId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
